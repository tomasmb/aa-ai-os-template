# Alpha AI OS — ritual schedule (cron)
#
# Append these lines to your crontab with:
#   crontab -l > /tmp/cron.bak && cat <this file> >> /tmp/cron.bak && crontab /tmp/cron.bak
#
# The assistant does this for you during onboarding. Below is the canonical
# content it installs. Placeholders <HH>, <MM>, <WEEKDAY>, <AI_OS_FOLDER>
# are filled from WORKSTYLE.md + USER.md before writing.
#
# Cron weekday: 0=Sunday, 1=Monday, ..., 5=Friday, 6=Saturday
# Default: weekly digest on Friday (5).
#
# Each ritual first runs scripts/preflight (KB clone health, Contract Rule 17)
# then scripts/sync-kb (git pull --rebase, Contract Rule 16). If either
# fails, the && short-circuits and the trigger is skipped — the next manual
# session surfaces the missed ritual via the standard "since-last-session"
# briefing. Choosing xdg-open as the default Linux opener; the assistant
# substitutes the right opener per detected AI tool during install.

# Morning check-in — weekdays at HH:MM
# The morning ritual is the canonical place for the daily assistant-repo
# pull (sync-assistant) so users always boot against fresh Contract / packs.
<MM> <HH> * * 1-5 /bin/bash -c '"<AI_OS_FOLDER>/scripts/sync-assistant" && "<AI_OS_FOLDER>/scripts/preflight" && "<AI_OS_FOLDER>/scripts/sync-kb" && xdg-open "claude://message?text=$(printf %s "/ritual morning — run the morning check-in for <AI_OS_FOLDER>" | jq -sRr @uri)" >> <AI_OS_FOLDER>/logs/ritual-morning.out.log 2>> <AI_OS_FOLDER>/logs/ritual-morning.err.log'

# End-of-day wrap — weekdays at HH:MM
<EOD_MM> <EOD_HH> * * 1-5 /bin/bash -c '"<AI_OS_FOLDER>/scripts/preflight" && "<AI_OS_FOLDER>/scripts/sync-kb" && xdg-open "claude://message?text=$(printf %s "/ritual eod — run the end-of-day wrap for <AI_OS_FOLDER>" | jq -sRr @uri)" >> <AI_OS_FOLDER>/logs/ritual-eod.out.log 2>> <AI_OS_FOLDER>/logs/ritual-eod.err.log'

# Weekly review + owner digest — configured weekday at HH:MM
<WK_MM> <WK_HH> * * <WEEKDAY> /bin/bash -c '"<AI_OS_FOLDER>/scripts/preflight" && "<AI_OS_FOLDER>/scripts/sync-kb" && xdg-open "claude://message?text=$(printf %s "/ritual weekly — run the weekly review + owner digest for <AI_OS_FOLDER>" | jq -sRr @uri)" >> <AI_OS_FOLDER>/logs/ritual-weekly.out.log 2>> <AI_OS_FOLDER>/logs/ritual-weekly.err.log'
